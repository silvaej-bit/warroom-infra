# ============================================================
# Dockerfile_backend_java21
# Multi-stage build: Maven build -> JRE 21 slim runtime
# Multi-platform: linux/amd64 + linux/arm64
# Supports optional BuildKit secret 'github_token' for
# private GitHub Packages dependencies (on-call-ao-common).
# ============================================================

# --- Stage 1: Build ---
FROM maven:3.9-eclipse-temurin-21-alpine AS builder

WORKDIR /build

COPY pom.xml .

# Configure Maven for GitHub Packages if secret is provided
RUN --mount=type=secret,id=github_token,required=false \
    if [ -f /run/secrets/github_token ]; then \
      mkdir -p /root/.m2 && \
      TOKEN=$(cat /run/secrets/github_token) && \
      printf '<settings><servers><server><id>github</id><username>x-access-token</username><password>%s</password></server></servers></settings>\n' "$TOKEN" > /root/.m2/settings.xml; \
    fi && \
    mvn dependency:go-offline -B

COPY src ./src

RUN mvn package -DskipTests -B && \
    mv target/*.jar target/app.jar

# --- Stage 2: Runtime ---
FROM eclipse-temurin:21-jre-alpine

RUN addgroup -S app && adduser -S app -G app

WORKDIR /app

COPY --from=builder /build/target/app.jar ./app.jar
RUN chown -R app:app /app

USER app

EXPOSE 8080

ENTRYPOINT ["java", "-XX:+UseContainerSupport", "-XX:MaxRAMPercentage=75.0", "-XX:InitialRAMPercentage=50.0", "-jar", "/app/app.jar"]